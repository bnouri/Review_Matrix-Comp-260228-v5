% ------------------------------------------------------
% Code Listing Configuration
% ------------------------------------------------------
\usepackage{listings}
\lstset{
	backgroundcolor=\color{backcolour},
	basicstyle=\ttfamily\footnotesize,
	breaklines=true,
	captionpos=b,
	keepspaces=true,
	numbers=left,
	numberstyle=\tiny\color{codegray},
	numbersep=8pt,
	xleftmargin=15pt,
	aboveskip=10pt,
	belowskip=10pt,
	tabsize=4,
	frame=none,
	mathescape=false,
	showtabs=false,
	showspaces=false,
	showstringspaces=false,
	commentstyle=\color{codegreen},
	keywordstyle=\color{magenta},
	stringstyle=\color{codepurple},
}

% Styles: C++, Python, Matlab, Bash, Git
\lstdefinestyle{cpp}{
	language=C++,
	commentstyle=\color{codegreen}\itshape,
	keywordstyle=\color{magenta},
	keywordstyle=[2]\color{codeblue},
	directivestyle=\color{codeteal},
	morekeywords=[2]{std, vector, string, unique_ptr, shared_ptr, auto, Eigen, MatrixXd}
}
\lstdefinestyle{python}{
	language=Python,
	commentstyle=\color{codegreen}\itshape,
	keywordstyle=\color{blue},
	keywordstyle=[2]\color{codeblue},
	morekeywords=[2]{numpy, scipy, matplotlib, self, print}
}
\lstdefinestyle{matlab}{
	language=Matlab,
	commentstyle=\color{codegreen},
	keywordstyle=\color{blue},
	keywordstyle=[2]\color{codemagenta},
	morekeywords=[2]{plot, zeros, eye, mldivide, inv}
}
\lstdefinestyle{bash}{
	language=bash,
	commentstyle=\color{codegreen},
	keywordstyle=\color{magenta},
	morekeywords=[2]{sudo, git, make, cmake, export}
}
\lstdefinestyle{git}{
	language=bash,
	keywordstyle=\color{magenta},
	keywordstyle=[2]\color{codeblue},
	morekeywords={git},
	morekeywords=[2]{add, commit, push, pull, branch, checkout, log}
}

% ------------------------------------------------------
% Shorthands & Custom Containers
% ------------------------------------------------------
\newcommand{\mat}[1]{\mathbf{#1}}           % Matrix (Bold Roman)
\newcommand{\op}[1]{\operatorname{#1}}      % Custom Operators
\newcommand{\trieq}{\triangleq}             % Defined as

% ------------------------------------------------------
% Shorthand writes
% ------------------------------------------------------
% --- Page & Layout Control ---
\newcommand{\np}{\null\par\vfill\clearpage\noindent}
\newcommand{\nl}{\null\par\noindent}

% --- Custom List Markers ---
% Marker: #1 = vertical raise (ex), #2 = scale, #3 = symbol
\newcommand{\Mark}[3]{%
  \nl%
  \raisebox{#1ex}{\scalebox{#2}{\textcolor{academicgreen}{#3}}}%
  \hspace*{0.5em}%
}

% --- Marker shortcuts ---
\newcommand{\nlb}{\Mark{0.1}{1.1}{\textbullet}}
\newcommand{\nlo}{\Mark{0.1}{1.1}{$\circ$}}
\newcommand{\nld}{\Mark{0.1}{1.1}{\textendash}}
\newcommand{\nlg}{\Mark{0.1}{1.1}{\textdagger}}
\newcommand{\nlgg}{\Mark{0.1}{1.1}{\textdaggerdbl}}
\newcommand{\nlt}{\Mark{0.1}{1.1}{$\blacktriangleright$}}

% --- Generic custom symbol ---
\newcommand{\newitem}[1]{\Mark{0.1}{1.1}{#1}}

% ------------------------------------------------------
% Boxes
% ------------------------------------------------------
\newtcolorbox{mybox}[1][gray]{
	colback=#1!5, colframe=#1!50, arc=2mm, boxrule=0.5pt,
	left=8pt, right=8pt, fontupper=\small, enhanced, breakable
}

% ------------------------------------------------------
% Title Slide
% ------------------------------------------------------
\DeclareRobustCommand{\addtitlepage}{
	\begin{frame}
		\titlepage
	\end{frame}
}

% ------------------------------------------------------
% Title  Slide
% ------------------------------------------------------
\DeclareRobustCommand{\addtoc}{
	\begin{frame}[t]{Table of Contents}
		%\setlength{\parskip}{-1em}
		\setstretch{0.8}
		%\small
		\vspace*{.1cm}
		\tableofcontents[
			hideallsubsections
		]
		\vfill
	\end{frame}
}

% ------------------------------------------------------
% Bibliography  Slide
% ------------------------------------------------------
\usepackage[backend=biber, style=ieee, sorting=nyt]{biblatex}
\addbibresource{./refs.bib}

\DeclareRobustCommand{\addbibilio}{
	\section{Bibiliography}
	\begin{frame}[t,allowframebreaks]{References}
		\nocite{*}  %Shows all entries
		\printbibliography
	\end{frame}
}

% ------------------------------------------------------
% Specialized Slides & Bibliography
% ------------------------------------------------------
\DeclareRobustCommand{\addlastslide}{
	{
			\setbeamercolor{background canvas}{bg=black!3}   % Soft off-white background (eye-friendly)
			\begin{frame}[plain,noframenumbering]
				\vfill
				\centering
				{\LARGE\bfseries\color{siemensgreen} Thank you}
				\vfill
			\end{frame}
			\setbeamercolor{background canvas}{bg=}  % Reset background for safety
		}
}


