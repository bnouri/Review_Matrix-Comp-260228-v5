%% Code Listing/snipet:
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\usepackage{listings}

\definecolor{backcolour}{rgb}{0.95,0.95,0.92}

\definecolor{codegray}{rgb}{0.5, 0.5, 0.5}
\definecolor{codepurple}{rgb}{0.58, 0, 0.82}
\definecolor{codemagenta}{rgb}{0.8, 0, 0.8}
\definecolor{codeteal}{rgb}{0, 0.5, 0.5}

% --- Global Listings Settings (Shared by all styles) ---
\lstset{
  backgroundcolor=\color{backcolour},
  basicstyle=\ttfamily\footnotesize,
  breaklines=true,
  captionpos=b,
  keepspaces=true,
  numbers=left,
  numberstyle=\tiny\color{codegray},
  numbersep=8pt,
  xleftmargin=15pt,
  aboveskip=10pt,
  belowskip=10pt,
  tabsize=4,
  frame=none,
  mathescape=false,  % Crucial: tells listings $ is just a character
  showtabs=false,
  showspaces=false,
  showstringspaces=false,
  commentstyle=\color{codegreen},
  keywordstyle=\color{magenta},
  numberstyle=\tiny\color{codegray},
  stringstyle=\color{codepurple},
  breakatwhitespace=false,
}

\lstdefinestyle{text}{
  language={},
}

% -------------------------------------------------------
% Style: Cpp
% -------------------------------------------------------
\lstdefinestyle{cpp}{
  language=C++,
  commentstyle=\color{codegreen}\itshape,
  keywordstyle=\color{magenta},
  keywordstyle=[2]\color{codeblue},
  stringstyle=\color{codepurple},
  directivestyle=\color{codeteal},
  % REMOVE any literate={\$}{{\$}} lines here
  morekeywords=[2]{
      std, cout, cin, endl, vector, string, map, set, list, pair,
      size_t, int8_t, int16_t, int32_t, int64_t, uint8_t,
      unique_ptr, shared_ptr, auto, nullptr, constexpr, noexcept
    }
}

% -------------------------------------------------------
% Style: Python
% -------------------------------------------------------
\lstdefinestyle{python}{
  language=Python,
  commentstyle=\color{codegreen}\itshape,
  keywordstyle=\color{blue},
  keywordstyle=[2]\color{codeblue},
  keywordstyle=[3]\color{codemagenta},
  stringstyle=\color{codepurple},
  morecomment=[s][\color{codegreen}]{"""}{"""},
  morecomment=[s][\color{codegreen}]{'''}{'''},
  morecomment=[f][\color{codeteal}]{@},
  tabsize=4,
  morekeywords=[2]{
      print, len, range, type, int, str, float, list, dict, open, super, self,
      True, False, None, Exception
    },
  morekeywords=[3]{
      __init__, __str__, __repr__, __len__, __main__, __name__
    }
}

% -------------------------------------------------------
% Style: Matlab
% -------------------------------------------------------
\lstdefinestyle{matlab}{
  language=Matlab,
  commentstyle=\color{codegreen},
  keywordstyle=\color{blue},
  keywordstyle=[2]\color{codemagenta},
  stringstyle=\color{codepurple},
  morekeywords={global, persistent, properties, methods, events, classdef},
  morekeywords=[2]{
      plot, figure, subplot, title, xlabel, ylabel, grid, hold,
      zeros, ones, eye, size, length, disp, fprintf, clear, clc
    }
}

% -------------------------------------------------------
% Style: Bash/Shell
% -------------------------------------------------------
\lstdefinestyle{bash}{
  language=bash,
  alsoletter={-},
  commentstyle=\color{codegreen},
  keywordstyle=\color{magenta},
  keywordstyle=[2]\color{codeblue},
  stringstyle=\color{codepurple},
  morekeywords=[2]{
      sudo, apt, git, chmod, mkdir, rm, cp, mv, cat, grep, sed, awk,
      curl, wget, systemctl, find, export, source, ssh
    },
  emph={USER, HOME, PATH, PWD, SHELL},
  emphstyle=\color{codeteal}
}

% -------------------------------------------------------
% Style: Git (Specialized)
% -------------------------------------------------------
\lstdefinestyle{git}{
  language=bash,
  commentstyle=\color{codegreen},
  keywordstyle=\color{magenta},          % 'git' command
  keywordstyle=[2]\color{codeblue},     % subcommands
  keywordstyle=[3]\color{codeteal},     % flags/options
  stringstyle=\color{codepurple},
  morekeywords={git},
  morekeywords=[2]{
      add, commit, push, pull, fetch, merge, rebase,
      branch, checkout, switch, restore, log, status,
      diff, config, init, remote, clone, stash, reset, tag
    },
  morekeywords=[3]{
      -m, -a, -p, -u, -d, -f, -b, --all, --force, --graph,
      --oneline, --decorate, --global, --hard, --soft
    },
  emph={master, main, origin, HEAD},
  emphstyle=\color{codemagenta}
}


