\definecolor{siemensblue}{rgb}{0.0, 0.06, 0.12}
\definecolor{academicblue}{rgb}{0.0, 0.2, 0.4}
\definecolor{academicgreen}{rgb}{0.0, 0.32, 0.22}
\definecolor{codegreen}{rgb}{0.1, 0.5, 0.2}
\definecolor{codeblue}{rgb}{0.15, 0.35, 0.65}
\definecolor{codered}{rgb}{0.7, 0.2, 0.2}
\definecolor{codegray}{rgb}{0.5, 0.5, 0.5}
\definecolor{codepurple}{rgb}{0.58, 0, 0.82}
\definecolor{codemagenta}{rgb}{0.8, 0, 0.8}
\definecolor{codeteal}{rgb}{0, 0.5, 0.5}
\definecolor{deepnavy}{rgb}{0.0, 0.0, 0.5} % Added missing definition
